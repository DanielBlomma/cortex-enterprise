{
  "name": "cortex-enterprise-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/local",
    "packages/cloud",
    "mcp"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w packages/core",
    "build:local": "npm run build -w packages/local",
    "build:cloud": "npm run build -w packages/cloud",
    "build:mcp": "npm run build -w mcp",
    "dev": "tsc -b --watch"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
