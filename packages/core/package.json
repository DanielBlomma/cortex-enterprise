{
  "name": "@danielblomma/cortex-core",
  "version": "0.2.0",
  "description": "Shared types and logic for Cortex Enterprise",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./license/check": {
      "types": "./dist/license/check.d.ts",
      "import": "./dist/license/check.js"
    },
    "./license/public-key": {
      "types": "./dist/license/public-key.d.ts",
      "import": "./dist/license/public-key.js"
    },
    "./telemetry/collector": {
      "types": "./dist/telemetry/collector.d.ts",
      "import": "./dist/telemetry/collector.js"
    },
    "./audit/writer": {
      "types": "./dist/audit/writer.d.ts",
      "import": "./dist/audit/writer.js"
    },
    "./audit/query": {
      "types": "./dist/audit/query.d.ts",
      "import": "./dist/audit/query.js"
    },
    "./rbac/check": {
      "types": "./dist/rbac/check.d.ts",
      "import": "./dist/rbac/check.js"
    },
    "./policy/store": {
      "types": "./dist/policy/store.d.ts",
      "import": "./dist/policy/store.js"
    },
    "./policy/injection": {
      "types": "./dist/policy/injection.d.ts",
      "import": "./dist/policy/injection.js"
    },
    "./policy/enforce": {
      "types": "./dist/policy/enforce.d.ts",
      "import": "./dist/policy/enforce.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielBlomma/cortex-enterprise.git",
    "directory": "packages/core"
  },
  "author": "Daniel Blomma",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  }
}
